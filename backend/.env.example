# ──────────────────────────────────────────────────────────
# Local Development
# ──────────────────────────────────────────────────────────

# Локальна база (за замовчуванням SQLite)
DATABASE_URL=sqlite:///./bazys.db

# Або локальна PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bazys

# ──────────────────────────────────────────────────────────
# Production — Render / Railway / Fly.io
# ──────────────────────────────────────────────────────────

# На Render цю змінну дає сама платформа при створенні Postgres.
# Не пиши тут реальні паролі — використовуй Environment Variables платформи.
# DATABASE_URL=postgresql://user:password@host:5432/bazys

# ──────────────────────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────────────────────

SECRET_KEY=change-me-in-production
ENVIRONMENT=development
